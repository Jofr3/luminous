{
  "name": "@luminous/backend",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir dist",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:migrate:local": "wrangler d1 migrations apply luminous-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply luminous-db --remote",
    "db:seed": "bun run scripts/seed.ts"
  },
  "dependencies": {
    "hono": "^4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4",
    "@luminous/typescript-config": "workspace:*",
    "typescript": "^5.7.0",
    "wrangler": "^4"
  }
}
